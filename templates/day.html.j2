<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 领袖动态 — {{ date }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #fafafa;
      color: #222;
      padding: 24px 20px;
      max-width: 760px;
      margin: 0 auto;
    }

    header {
      border-bottom: 2px solid #222;
      padding-bottom: 14px;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 8px;
    }
    header h1 { font-size: 20px; font-weight: bold; letter-spacing: -0.5px; }
    .meta { font-size: 12px; color: #666; }

    .entry {
      border: 1px solid #ddd;
      background: #fff;
      margin-bottom: 14px;
      padding: 16px;
    }

    .entry-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }
    .avatar {
      width: 28px; height: 28px;
      border: 1px solid #ddd; border-radius: 50%;
      background: #eee;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; color: #888;
      flex-shrink: 0;
      font-weight: 600;
    }
    .person-name { font-size: 13px; font-weight: 600; }
    .source-badge {
      font-size: 10px;
      border: 1px solid #bbb;
      padding: 1px 6px;
      color: #666;
    }
    .entry-time { font-size: 11px; color: #999; margin-left: auto; }

    .entry-title {
      font-size: 14px;
      font-weight: 600;
      color: #111;
      margin-bottom: 6px;
      line-height: 1.5;
    }
    .zh-content {
      font-size: 14px;
      line-height: 1.7;
      color: #333;
      margin-bottom: 10px;
    }
    .en-content {
      font-size: 12px;
      line-height: 1.6;
      color: #888;
      border-left: 2px solid #eee;
      padding-left: 10px;
      margin-bottom: 12px;
    }
    .entry-footer { display: flex; align-items: center; }
    .source-link {
      font-size: 11px;
      color: #555;
      text-decoration: none;
      border-bottom: 1px dotted #aaa;
    }
    .source-link:hover { color: #000; }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #999;
      font-size: 14px;
      border: 1px dashed #ddd;
      background: #fff;
    }

    footer {
      border-top: 1px solid #ddd;
      margin-top: 28px;
      padding-top: 12px;
      font-size: 11px;
      color: #999;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 6px;
    }
    footer a { color: #999; }
  </style>
</head>
<body>

<header>
  <h1>AI 领袖动态</h1>
  <div class="meta">{{ date }} · {{ entries|length }} 条更新 · 自动生成</div>
</header>

{% if entries %}
  {% for entry in entries %}
  <div class="entry">
    <div class="entry-header">
      <div class="avatar">{{ entry.person_name[0] }}</div>
      <span class="person-name">{{ entry.person_name }}</span>
      <span class="source-badge">Twitter</span>
      <span class="entry-time">{{ entry.created_at }}</span>
    </div>

    {% if entry.title and entry.title != "（原文）" and entry.title != "（无标题）" %}
    <div class="entry-title">{{ entry.title }}</div>
    {% endif %}

    <div class="zh-content">{{ entry.summary }}</div>

    <div class="en-content">"{{ entry.original_text }}"</div>

    <div class="entry-footer">
      <a class="source-link" href="{{ entry.tweet_url }}" target="_blank" rel="noopener">→ 原始推文</a>
    </div>
  </div>
  {% endfor %}
{% else %}
  <div class="empty-state">今日无新内容</div>
{% endif %}

<footer>
  <span>由 GitHub Actions 自动生成 · 每日 09:00 BJT 更新</span>
  <span><a href="archive/">历史存档</a></span>
</footer>

</body>
</html>
